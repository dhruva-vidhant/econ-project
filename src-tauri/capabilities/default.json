{
  "$schema": "../gen/schemas/desktop-schema.json",
  "identifier": "default",
  "description": "Default capability for the main window: only the typed IPC commands the WebView is allowed to invoke.",
  "windows": ["main"],
  "permissions": [
    "core:default",
    "core:window:default",
    "core:event:default",
    "core:webview:allow-create-webview-window",
    "dialog:default"
  ]
}
